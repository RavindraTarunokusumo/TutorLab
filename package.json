{
  "name": "tutorlab",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run prisma:generate && npm run prisma:migrate:deploy && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:fixture": "node tests/e2e/run-fixture.mjs",
    "test:e2e:ui": "playwright test --ui",
    "prisma": "node scripts/prisma.mjs",
    "prisma:generate": "npm run prisma -- generate",
    "prisma:migrate:deploy": "npm run prisma -- migrate deploy",
    "prisma:validate": "npm run prisma -- validate",
    "db:push": "npm run prisma -- db push",
    "db:migrate": "npm run prisma -- migrate dev",
    "db:studio": "npm run prisma -- studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jszip": "3.10.1",
    "katex": "^0.18.0",
    "lucide-react": "1.24.0",
    "mammoth": "1.12.0",
    "next": "15.5.20",
    "openai": "6.47.0",
    "pdfjs-dist": "5.4.530",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "0.0.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@next/env": "15.5.20",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.11",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/ui": "4.1.10",
    "eslint": "9.39.2",
    "eslint-config-next": "15.5.20",
    "jsdom": "29.1.1",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
